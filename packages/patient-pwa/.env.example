# API configuration
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_API_VERSION=v1

# Optional: override websocket origin/path
# NEXT_PUBLIC_WS_URL=ws://localhost:3000
# NEXT_PUBLIC_WS_NOTIFICATIONS_PATH=/ws/notifications

# Web Push (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Local push testing (development only)
# Set true only when you intentionally want SW + push enabled in dev.
# ENABLE_PUSH_IN_DEV=true
