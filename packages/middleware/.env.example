# Database Configuration
DATABASE_URL="postgresql://carebridge_user:carebridge_dev_password@localhost:5432/carebridge_db"

# Server Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1
API_PREFIX=/api/v1
SWAGGER_ENABLED=true

# JWT Configuration
JWT_SECRET=dev_jwt_secret_key_change_in_production
JWT_EXPIRATION=86400 # 24 hours in seconds
JWT_REFRESH_EXPIRATION=2592000 # 30 days in seconds

# Public app URL used in password reset emails
APP_PUBLIC_URL=http://localhost:3001
PASSWORD_RESET_TTL_MINUTES=30

# Plunk Email Delivery
PLUNK_API_URL=https://next-api.useplunk.com
PLUNK_SECRET_KEY=sk_your_plunk_secret_key

# OAuth2 Configuration
OAUTH2_HOSPITAL_SECRET=dev_oauth2_secret_key

# CORS Configuration
# Comma-separated allowed origins
CORS_ORIGIN=http://localhost:3001,http://127.0.0.1:3001,http://localhost:3002,http://127.0.0.1:3002

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Security
BCRYPT_ROUNDS=10
ENCRYPTION_KEY=dev_encryption_key_min_32_chars_!!!
TRUST_PROXY=false
ENFORCE_HTTPS=false

# Features
ENABLE_WEBSOCKET_NOTIFICATIONS=true
ENABLE_DEFENSE_DEMO_WS=true
DEFENSE_DEMO_TOKEN=carebridge-defense-demo
DEFENSE_HOSPITAL_A_ENDPOINT=http://localhost:4001
DEFENSE_HOSPITAL_B_ENDPOINT=http://localhost:4002
ENABLE_PUSH_NOTIFICATIONS=false
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@carebridge.local
ENABLE_EMAIL_VERIFICATION=false
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100
