# Database Configuration
DATABASE_URL="postgresql://carebridge_user:carebridge_dev_password@localhost:5432/carebridge_db"

# Server Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1
API_PREFIX=/api/v1

# JWT Configuration
JWT_SECRET=dev_jwt_secret_key_change_in_production
JWT_EXPIRATION=86400 # 24 hours in seconds
JWT_REFRESH_EXPIRATION=2592000 # 30 days in seconds

# OAuth2 Configuration
OAUTH2_HOSPITAL_SECRET=dev_oauth2_secret_key

# CORS Configuration
CORS_ORIGIN=http://localhost:3001

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Security
BCRYPT_ROUNDS=10
ENCRYPTION_KEY=dev_encryption_key_min_32_chars_!!!

# Features
ENABLE_WEBSOCKET_NOTIFICATIONS=true
ENABLE_PUSH_NOTIFICATIONS=false
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@carebridge.local
ENABLE_EMAIL_VERIFICATION=false
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100
